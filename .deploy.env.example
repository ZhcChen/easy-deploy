# Copy this file to .deploy.env and fill your API tokens.
#
# Remote alias rule:
#   --remote local reads EASY_DEPLOY_LOCAL_URL and EASY_DEPLOY_LOCAL_TOKEN.
#   --remote prod reads EASY_DEPLOY_PROD_URL and EASY_DEPLOY_PROD_TOKEN.
#
# Tokens are generated in the Easy Deploy API Token page.

EASY_DEPLOY_LOCAL_URL=http://127.0.0.1:9066
EASY_DEPLOY_LOCAL_TOKEN=

EASY_DEPLOY_TEST_URL=http://127.0.0.1:9066
EASY_DEPLOY_TEST_TOKEN=

EASY_DEPLOY_PROD_URL=https://deploy.example.com
EASY_DEPLOY_PROD_TOKEN=

# Optional defaults for a business project.
EASY_DEPLOY_SERVICE_KEY=
EASY_DEPLOY_ENTRY_FILE=
EASY_DEPLOY_SOURCE=script
